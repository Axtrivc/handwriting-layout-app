{
  "name": "@hw-layout/desktop",
  "private": true,
  "version": "0.8.0",
  "description": "Electron 桌面壳：个人笔记美化、扫描稿恢复、模板重排版、个人手写风格排版。",
  "main": "dist/main.cjs",
  "type": "commonjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "esbuild src/main.ts --bundle --platform=node --format=cjs --outfile=dist/main.cjs --external:electron",
    "build:desktop": "pnpm run build",
    "start": "electron .",
    "start:prod": "cross-env HW_API_BASE=http://127.0.0.1:8001 electron .",
    "package:desktop": "echo '[TODO] 安装 electron-builder 后运行: pnpm --filter @hw-layout/desktop exec electron-builder --dir' && exit 0",
    "package:dist": "echo '[TODO] 安装 electron-builder 后运行: pnpm --filter @hw-layout/desktop exec electron-builder' && exit 0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "build": {
    "appId": "com.handwriting-layout.app",
    "productName": "Handwriting Layout",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../apps/web/dist",
        "to": "web-dist"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.17.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
