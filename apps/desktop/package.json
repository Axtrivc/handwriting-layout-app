{
  "name": "@hw-layout/desktop",
  "private": true,
  "version": "0.1.0",
  "main": "dist/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -b && esbuild src/main.ts --bundle --platform=node --format=cjs --outfile=dist/main.cjs --external:electron",
    "start": "electron .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
